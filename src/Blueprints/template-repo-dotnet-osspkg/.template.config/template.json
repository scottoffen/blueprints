{
  "$schema": "http://json.schemastore.org/template",
  "author": "Scott Offen",
  "classifications": [
    "Library",
    "OSS",
    "NuGet",
    "GitHub"
  ],
  "name": "Open Source .NET Package",
  "description": "Repository structure for an open source C# package with docs, versioning, and CI/CD.",
  "identity": "ScottOffen.Blueprints.OssPkg",
  "shortName": "osspkg",
  "defaultName": "Blueprint",
  "sourceName": "Blueprint",
  "preferNameDirectory": false,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "symbols": {
    "org": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "scottoffen",
      "description": "The GitHub organization name.",
      "replaces": "$(GitHubOrg)"
    },
    "repo": {
      "type": "parameter",
      "datatype": "string",
      "isRequired": true,
      "description": "The GitHub repository name.",
      "replaces": "$(GitHubRepo)"
    },
    "authorName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "Scott Offen",
      "description": "The name of the package author.",
      "replaces": "$(AuthorName)"
    },
    "version": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "1.0.0-preview.{height}",
      "description": "The initial version for Nerdbank.GitVersioning.",
      "replaces": "$(VersionPrefix)"
    },
    "currentYear": {
      "type": "generated",
      "generator": "now",
      "replaces": "$(CurrentYear)",
      "parameters": {
        "format": "yyyy"
      }
    }
  },
  "sources": [
    {
      "source": "../_shared",
      "target": "./",
      "include": [
        ".editorconfig",
        ".gitignore",
        "test-coverage.ps1",
        "DOCUSAURUS.md",
        "LICENSE-MIT",
        "LICENSE-APACHE",
        "STRONG_NAMING.md"
      ]
    },
    {
      "source": "../_shared/.github",
      "target": "./.github/"
    },
    {
      "source": "../_shared/src",
      "target": "./src/",
      "include": [
        ".config/dotnet-tools.json",
        "coverlet.runsettings",
        "Directory.Build.props",
        "version.json"
      ]
    },
    {
      "source": "./",
      "target": "./"
    }
  ]
}